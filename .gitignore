# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local AI tooling — installed-on-demand, not project code
.agents/
.codebuddy/
.continue/
.omc/
.playwright-mcp/
skills-lock.json

# .claude — block per-machine state, ALLOW project config + hooks
# (settings.local.json is the per-user override — contains absolute paths
#  + permission allowlists specific to the local user, must stay local)
.claude/*
!.claude/settings.json
!.claude/hooks/
!.claude/hooks/**

# Per-session critique / audit reports written to repo root by subagents
critique-*/
audit-*/

# Test outputs
test-results/
/playwright-report/

# Dev / debug / critique screenshots at repo root
# (production assets live under public/ or app/)
/*.png
